# ─────────────────────────────────────────────
# RADD — Environment Configuration
# Copy to .env and fill in values before running
# ─────────────────────────────────────────────

# Application
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=true

# PostgreSQL (Neon in production, local docker in dev)
POSTGRES_USER=radd
POSTGRES_PASSWORD=radd_dev_password
POSTGRES_DB=radd_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://radd:radd_dev_password@localhost:5432/radd_dev

# Redis (Upstash in production, local docker in dev)
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                   # leave empty for local dev

# MinIO / S3
MINIO_ROOT_USER=radd_minio
MINIO_ROOT_PASSWORD=radd_minio_password
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=radd_minio
S3_SECRET_KEY=radd_minio_password
S3_BUCKET_NAME=radd-dev

# JWT
JWT_SECRET_KEY=change-me-to-a-different-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# WhatsApp Cloud API
META_APP_SECRET=                   # from Meta developer portal
META_VERIFY_TOKEN=                 # your custom webhook verify token
WA_PHONE_NUMBER_ID=                # WhatsApp Business phone number ID
WA_BUSINESS_ACCOUNT_ID=            # WhatsApp Business Account ID
WA_API_TOKEN=                      # permanent or system user token
WA_API_VERSION=v21.0

# OpenAI
OPENAI_API_KEY=                    # sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Salla
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=

# Confidence thresholds (defaults, overridable per workspace)
CONFIDENCE_AUTO_THRESHOLD=0.85
CONFIDENCE_SOFT_ESCALATION_THRESHOLD=0.60

# ─────────────────────────────────────────────
# PRODUCTION OVERRIDES (fill these for prod)
# ─────────────────────────────────────────────

# Neon serverless PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.eu-central-1.aws.neon.tech/radd?sslmode=require

# Upstash Redis (production)
# REDIS_URL=rediss://default:token@global-xxx.upstash.io:6380

# Qdrant Cloud (production) — or keep local qdrant container
# QDRANT_URL=https://xxx.cloud.qdrant.io
# QDRANT_API_KEY=your-qdrant-cloud-api-key

# AWS S3 (production)
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=...
# S3_BUCKET_NAME=radd-prod
# AWS_REGION=me-south-1

# CORS (production)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend URL (used in links, emails)
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_WS_URL=wss://yourdomain.com

# Grafana / monitoring (optional)
GRAFANA_URL=
GRAFANA_API_KEY=
